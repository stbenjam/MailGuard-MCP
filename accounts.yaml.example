accounts:
  personal:
    provider: imap
    imap_host: imap.gmail.com
    imap_port: 993
    imap_tls: true
    imap_username: you@gmail.com
    imap_password_env: PERSONAL_IMAP_PASSWORD
    imap_mailbox: INBOX
    # imap_drafts_mailbox: "[Gmail]/Drafts"  # default: Drafts
    # imap_exclude_folders:  # folders excluded from cross-folder search
    #   - Trash              # default: Trash, Spam, Junk, Drafts, Sent
    #   - Spam

  work:
    provider: imap
    imap_host: imap.fastmail.com
    imap_port: 993
    imap_tls: true
    imap_username: you@company.com
    imap_password_env: WORK_IMAP_PASSWORD
    imap_mailbox: INBOX
    # imap_drafts_mailbox: "[Gmail]/Drafts"  # default: Drafts
