accounts:
  personal:
    provider: imap
    imap_host: imap.gmail.com
    imap_port: 993
    imap_tls: true
    imap_username: you@gmail.com
    imap_password_env: PERSONAL_IMAP_PASSWORD
    imap_mailbox: INBOX
    # imap_drafts_mailbox: "[Gmail]/Drafts"  # default: Drafts

  work:
    provider: imap
    imap_host: imap.fastmail.com
    imap_port: 993
    imap_tls: true
    imap_username: you@company.com
    imap_password_env: WORK_IMAP_PASSWORD
    imap_mailbox: INBOX
    # imap_drafts_mailbox: "[Gmail]/Drafts"  # default: Drafts
