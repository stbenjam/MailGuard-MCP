# Mail provider: "imap" (future: "gmail")
MAIL_PROVIDER=imap

# IMAP settings
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=user@example.com
IMAP_PASSWORD=app-password-here
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# Trust store database path
TRUSTSTORE_DB_PATH=./truststore.db

# Directory to save downloaded attachments
ATTACHMENT_DIR=./attachments

# Max body text in bytes returned to LLM (default 32KB)
MAX_BODY_SIZE=32768

# Pre-seed trusted senders (comma-separated, supports @domain.com for domain trust)
TRUSTED_SENDERS=
